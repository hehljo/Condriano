# ===========================================
# Condriano - Configuration
# Copy this file to .env and fill in your values
# cp .env.example .env
# ===========================================

# --- Telegram Bot (REQUIRED) ---
# Create a bot: Talk to @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram Chat ID: Talk to @userinfobot → /start
TELEGRAM_CHAT_ID=your_chat_id_here

# --- Trading 212 (OPTIONAL) ---
# Get your API key: Trading 212 App → Settings → API
# Leave empty to run without live trading
T212_API_KEY=
T212_API_SECRET=

# Mode: 'live' for real money, 'practice' for paper trading
# WARNING: 'live' means REAL trades with REAL money!
T212_MODE=practice
